// Cambiamos la versión a v3 para que el navegador actualice la app obligatoriamente
const CACHE_NAME = 'cam-pwa-gps-voz-v3';

// Añadimos los recursos externos del mapa para que funcionen sin conexión
const ASSETS = [
  'index.html',
  'manifest.json',
  'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css',
  'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'
];

// Instalar y guardar archivos en caché
self.addEventListener('install', (e) => {
  e.waitUntil(
    caches.open(CACHE_NAME).then((cache) => {
      console.log('Archivos en caché actualizados con éxito');
      return cache.addAll(ASSETS);
    })
  );
  // Fuerza al Service Worker a activarse inmediatamente
  self.skipWaiting();
});

// Limpiar cachés antiguos al activarse
self.addEventListener('activate', (e) => {
  e.waitUntil(
    caches.keys().then((cacheNames) => {
      return Promise.all(
        cacheNames.map((cache) => {
          if (cache !== CACHE_NAME) {
            console.log('Borrando caché antiguo:', cache);
            return caches.delete(cache);
          }
        })
      );
    })
  );
});

// Responder desde el caché si no hay internet (Offline support)
self.addEventListener('fetch', (e) => {
  e.respondWith(
    caches.match(e.request).then((response) => {
      // Devuelve lo que hay en caché, o hace la petición a la red si no está
      return response || fetch(e.request);
    })
  );
});